<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.D308VacationPlanner">
        <activity
            android:name=".UI.SearchActivity"
            android:label="Search"
            android:parentActivityName=".UI.MainActivity"
            android:exported="false" />
        <activity
            android:name=".UI.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".UI.MyReceiver"
            android:enabled="true"
            android:exported="true" />

        <activity
            android:name=".UI.ExcursionDetailActivity"
            android:exported="false"
            android:label="Excursion Details"
            android:parentActivityName=".UI.VacationDetailActivity"
            android:theme="@style/Theme.D308VacationPlanner" />
        <activity
            android:name=".UI.VacationDetailActivity"
            android:exported="false"
            android:label="Vacation Details"
            android:parentActivityName=".UI.VacationActivity" />
        <activity
            android:name=".UI.VacationActivity"
            android:exported="false"
            android:label="Vacations"
            android:parentActivityName=".UI.MainActivity" />
        <activity
            android:name=".UI.MainActivity"
            android:exported="true"
            android:label="Welcome">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
            </intent-filter>
        </activity>
    </application>

</manifest>